<Window x:Class="LibraryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Manager" Height="700" Width="1200">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,0" Height="35">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="TxtSearch" Width="300" Padding="5" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Найти" Width="80" Margin="10,0,0,0" Click="SearchButton_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Content="Показать все" Width="100" Margin="10,0,0,0" Click="ShowAll_Click"/>
        </StackPanel>

        <!-- Фильтрация -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,10,10,10" Height="35">
            <TextBlock Text="Фильтр по автору:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox x:Name="ComboAuthors" Width="200" ItemsSource="{Binding Authors}" DisplayMemberPath="LastName" SelectedItem="{Binding SelectedAuthor}" VerticalAlignment="Center"/>

            <TextBlock Text="Фильтр по жанру:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
            <ComboBox x:Name="ComboGenres" Width="200" ItemsSource="{Binding Genres}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedGenre}" VerticalAlignment="Center"/>

            <Button Content="Применить фильтр" Width="120" Margin="20,0,0,0" Click="FilterButton_Click" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
            <Button Content="Очистить" Width="80" Margin="10,0,0,0" Click="ClearFilter_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="DataGridBooks" AutoGenerateColumns="False" Margin="10,0,10,10" 
                  ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.FirstName}" Width="150"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Author.LastName}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="Экземпляры" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки CRUD -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10,0,10,10" Height="40">
            <Button Content="+ Добавить книгу" Width="120" Click="AddBook_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="✎ Редактировать" Width="120" Click="EditBook_Click" Background="#FF9800" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="✕ Удалить" Width="100" Click="DeleteBook_Click" Background="#F44336" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            
            <Separator Width="20" Visibility="Hidden"/>
            
            <Button Content="👤 Управление авторами" Width="160" Click="ManageAuthors_Click" Background="#673AB7" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="📚 Управление жанрами" Width="160" Click="ManageGenres_Click" Background="#E91E63" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>