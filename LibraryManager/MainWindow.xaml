<Window x:Class="LibraryManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Manager" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="DataGridBooks" AutoGenerateColumns="False" Margin="10,50,10,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" />
                <DataGridTextColumn Header="Author" Binding="{Binding Author.LastName}" />
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre.Name}" />
                <DataGridTextColumn Header="Year" Binding="{Binding PublishYear}" />
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" />
                <DataGridTextColumn Header="Quantity" Binding="{Binding QuantityInStock}" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBox x:Name="TxtSearch" Width="200" Height="25" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <Button Content="Load Books" Width="100" Height="25" Margin="220,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Click="LoadBooks_Click"/>
    </Grid>
</Window>